---
const year = new Date().getFullYear();
---
<footer class="no-print rule-t mt-24">
  <div
    class="mx-auto max-w-3xl px-6 py-8 flex flex-wrap items-baseline justify-between gap-4 text-[10px] uppercase tracking-[0.2em] text-muted-foreground"
  >
    <span>© {year} Vijo Cherian</span>
    <div class="flex gap-7">
      <a href="mailto:hello@example.com" class="transition-colors hover:text-foreground">Email</a>
      <a
        href="https://github.com"
        target="_blank"
        rel="noreferrer"
        class="transition-colors hover:text-foreground">GitHub</a
      >
      <a
        href="https://x.com"
        target="_blank"
        rel="noreferrer"
        class="transition-colors hover:text-foreground">X</a
      >
    </div>
  </div>
</footer>
