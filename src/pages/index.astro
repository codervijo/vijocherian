---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { projects, posts, formatDate, formatNum } from "../lib/content";

const site = "https://vijocherian.com";
const title = "Vijo Cherian — Independent founder and builder";
const description =
  "Independent founder and builder working on Swiftly, a TV platform, and creator tooling.";

const building = projects.filter((p) => p.status === "building" || p.status === "live");
const recent = posts.slice(0, 3);
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Vijo Cherian" />
    <link rel="canonical" href={site + "/"} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Vijo Cherian" />
    <meta property="og:description" content="Independent founder and builder." />
    <meta property="og:url" content="https://vijocherian.com/" />
    <meta property="og:site_name" content="Vijo Cherian" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Vijo Cherian" />
    <meta name="twitter:description" content="Independent founder and builder." />

    <!-- JSON-LD structured data: Organization + WebSite -->
    <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://vijocherian.com/#organization",
      "name": "Vijo Cherian",
      "url": "https://vijocherian.com/"
    },
    {
      "@type": "WebSite",
      "@id": "https://vijocherian.com/#website",
      "url": "https://vijocherian.com/",
      "name": "Vijo Cherian",
      "publisher": { "@id": "https://vijocherian.com/#organization" }
    }
  ]
}
    </script>
  </head>
  <body>
    <div class="min-h-screen flex flex-col">
      <Header />
      <main class="flex-1">
        <div class="mx-auto max-w-3xl px-6 fade-in">
          <section class="pt-16 pb-20">
            <div class="mb-8 flex items-center gap-3">
              <span class="tag">[00]</span>
              <span class="label-accent">Core_Intel</span>
            </div>
            <div class="grid md:grid-cols-[1fr_180px] gap-12">
              <div>
                <h1 class="text-2xl sm:text-3xl tracking-tight max-w-2xl text-foreground leading-snug">
                  Vijo Cherian. Independent founder and builder.{" "}
                  <span class="text-muted-foreground">Currently working on a</span>{" "}
                  <span style="color: var(--color-accent)">YouTube trend detection pipeline</span>
                  <span class="text-muted-foreground">
                    , a channel-based video platform, and free tools for creators.</span
                  >
                </h1>
                <p
                  class="mt-8 text-[13px] max-w-xl italic"
                  style="border-left: 0.5px solid var(--color-rule); padding-left: 1rem; color: var(--color-muted-foreground)"
                >
                  Background in embedded Linux, Kubernetes, and cloud infrastructure.
                </p>
                <p class="mt-6 text-[13px] text-muted-foreground max-w-xl leading-relaxed">
                  Previously in engineering and product. Based remotely. Writing occasionally about
                  search, programmatic SEO, and what it actually takes to ship things alone.
                </p>
              </div>
              <div class="hidden md:block text-[10px] space-y-3 rule-l pl-6">
                <div class="uppercase tracking-widest" style="color: var(--color-tertiary)">
                  Status
                </div>
                <div class="flex items-center gap-2">
                  <span
                    aria-hidden
                    class="inline-block w-1.5 h-1.5 rounded-full animate-pulse"
                    style="background: var(--color-accent)"></span>
                  <span class="text-foreground tracking-widest">AVAILABLE</span>
                </div>
                <div class="uppercase tracking-widest pt-4" style="color: var(--color-tertiary)">
                  Location
                </div>
                <div class="text-foreground tracking-widest">REMOTE_OS</div>
              </div>
            </div>
          </section>

          <div class="flex items-end justify-between mb-6 rule-b pb-3">
            <div class="flex items-center gap-3">
              <span class="tag">[01]</span>
              <h2 class="label-accent">Active_Processes</h2>
            </div>
            <a href="/projects" class="label-accent transition-colors hover:!text-foreground">
              View Registry →
            </a>
          </div>
          <ul>
            {
              building.map((p, i) => (
                <li class="row-hover rule-b py-5 px-3 -mx-3 grid grid-cols-[2.5rem_1fr_auto] gap-4 items-center">
                  <span class="num text-xs">{formatNum(i + 1)}</span>
                  <div>
                    <div class="text-sm font-semibold text-foreground">{p.name}</div>
                    <div class="text-[11px] text-muted-foreground mt-0.5">{p.description}</div>
                  </div>
                  <span class:list={["chip", p.status === "live" && "chip-live"]}>{p.status}</span>
                </li>
              ))
            }
          </ul>

          <div class="mt-20"></div>
          <div class="flex items-end justify-between mb-6 rule-b pb-3">
            <div class="flex items-center gap-3">
              <span class="tag">[02]</span>
              <h2 class="label-accent">Stored_Entries</h2>
            </div>
            <a href="/writing" class="label-accent transition-colors hover:!text-foreground">
              Archive →
            </a>
          </div>
          <ul>
            {
              recent.map((p, i) => (
                <li class="row-hover rule-b py-5 px-3 -mx-3">
                  <a
                    href={`/writing/${p.slug}`}
                    class="grid grid-cols-[2.5rem_1fr_auto] gap-4 items-center group"
                  >
                    <span class="num text-xs">{formatNum(i + 1)}</span>
                    <div>
                      <div class="text-sm font-semibold text-foreground transition-colors group-hover:text-[var(--color-accent)]">
                        {p.title}
                      </div>
                      <div class="text-[11px] text-muted-foreground mt-1">{p.description}</div>
                    </div>
                    <span class="num text-[10px] whitespace-nowrap uppercase tracking-widest">
                      {formatDate(p.date)}
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </main>
      <Footer />
    </div>
  </body>
</html>
