---
import { marked } from "marked";
import Layout from "../../layouts/Layout.astro";
import { posts, formatDate } from "../../lib/content";

export function getStaticPaths() {
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

marked.setOptions({ gfm: true, breaks: false });

const { post } = Astro.props;

const html = marked.parse(post.body) as string;
const bodyHtml = html.replace(/^\s*<h1[^>]*>.*?<\/h1>/i, "");

const idx = posts.findIndex((p) => p.slug === post.slug);
const prev = posts[idx + 1];
const next = posts[idx - 1];

const title = `${post.title} — Vijo Cherian`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.title,
  datePublished: post.date,
  author: { "@type": "Person", name: "Vijo Cherian" },
};
---
<Layout
  title={title}
  description={post.description}
  canonical={`https://vijocherian.com/writing/${post.slug}`}
  ogType="article"
  ogUrl={`https://vijocherian.com/writing/${post.slug}`}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-2xl px-6 fade-in">
    <header class="pt-16 pb-10 rule-b">
      <div class="flex items-baseline gap-3 mb-6">
        <a href="/writing" class="label hover-underline">← Writing</a>
      </div>
      <h1 class="text-3xl sm:text-4xl tracking-tight">{post.title}</h1>
      <div class="mt-5 flex gap-4 num text-sm">
        <time datetime={post.date}>{formatDate(post.date)}</time>
        <span>·</span>
        <span>{post.readingTime}</span>
      </div>
    </header>

    <div class="prose-editorial pt-8 text-[1.05rem]" set:html={bodyHtml} />

    <nav class="mt-20 rule-t pt-6 grid grid-cols-2 gap-6 text-sm">
      <div>
        {
          prev && (
            <a href={`/writing/${prev.slug}`} class="block group">
              <div class="label mb-1">Previous</div>
              <div class="group-hover:underline underline-offset-4">{prev.title}</div>
            </a>
          )
        }
      </div>
      <div class="text-right">
        {
          next && (
            <a href={`/writing/${next.slug}`} class="block group">
              <div class="label mb-1">Next</div>
              <div class="group-hover:underline underline-offset-4">{next.title}</div>
            </a>
          )
        }
      </div>
    </nav>
  </article>
</Layout>
